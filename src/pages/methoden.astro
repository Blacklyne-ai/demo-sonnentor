---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { methods, angebote } from '../data/methods';
---
<Layout title="Heilmethoden" description="Geistiges Heilen, Clearing, Hypnose, Meditation, Energiemassagen und Qi Gong - die Methoden der Gesundheitspraxis SonnenTor, sowie alle Anwendungen im Überblick." current="/methoden">
  <PageHero
    eyebrow="Methoden"
    title="Die Wege, auf denen ich arbeite."
    lead="Sechs Methoden, die ich je nach Mensch und Anliegen miteinander verbinde - ruhig, achtsam und immer im Gespräch abgestimmt."
    breadcrumb={[{ label: 'Methoden' }]}
  />

  <section class="bg-paper">
    <div class="container-x py-16 lg:py-24">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {methods.map((m) => (
          <ServiceCard href={`/methoden/${m.slug}`} icon={m.icon} title={m.name} blurb={m.short} image={m.image} cta="Mehr erfahren" />
        ))}
      </div>
    </div>
  </section>

  <!-- Vollständiges Leistungsverzeichnis (verbatim alte Site) -->
  <section class="bg-sand">
    <div class="container-x py-16 lg:py-24">
      <div class="reveal mx-auto max-w-2xl text-center">
        <span class="eyebrow no-rule mb-4 justify-center">Alles auf einen Blick</span>
        <h2 class="text-balance text-3xl text-ink sm:text-4xl">Anwendungen &amp; Angebote im Überblick.</h2>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Die meisten Disharmonien unseres Körpers gehen auf Immunschwächen zurück. Deshalb arbeite ich
          an den Ursachen - und begleite bei vielen unterschiedlichen Themen.
          <span class="mt-2 block font-display text-lg text-clay-ink">„Ein Versuch ist es immer wert."</span>
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {angebote.map((a) => (
          <div class="reveal flex flex-col rounded-3xl border border-line bg-white p-6 shadow-soft">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep">
              <Icon name={a.icon} size={21} strokeWidth={1.8} />
            </span>
            <h3 class="mt-4 font-display text-lg text-ink">{a.title}</h3>
            <ul class="mt-4 flex-1 space-y-2 text-[0.92rem] leading-relaxed text-ink-soft">
              {a.items.map((it) => (
                <li class="flex items-start gap-2.5">
                  <Icon name="Check" size={15} class="mt-1 shrink-0 text-clay-deep" strokeWidth={2.4} />{it}
                </li>
              ))}
            </ul>
            <a href={`/methoden/${a.method}`} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-clay-deep hover:text-clay-ink">
              {a.methodName}<Icon name="ArrowRight" size={15} />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
