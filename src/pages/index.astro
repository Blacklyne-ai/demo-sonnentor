---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import LiveStatus from '../components/LiveStatus.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Sprechzeiten from '../components/Sprechzeiten.astro';
import ContactTiles from '../components/ContactTiles.astro';
import MapBlock from '../components/MapBlock.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import Social from '../components/Social.astro';
import CtaBand from '../components/CtaBand.astro';
import { site, videos, introVideo } from '../data/site';
import { methods } from '../data/methods';
import { treatments, wochenprogramm } from '../data/treatments';
const weitere = treatments.filter((t) => t.slug !== 'begleitende-behandlung');
---
<Layout floating={true} current="/">
  <!-- LCP-Hero vorab laden (passend zum <picture> je Viewport) -->
  <link slot="head" rel="preload" as="image" type="image/webp" href="/images/hope-hero-900.webp" media="(max-width: 700px)" />
  <link slot="head" rel="preload" as="image" type="image/webp" href="/images/hope-hero.webp" media="(min-width: 701px)" />

  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <picture>
        <source type="image/webp" media="(max-width: 700px)" srcset="/images/hope-hero-900.webp" />
        <source type="image/webp" srcset="/images/hope-hero.webp" />
        <img src="/images/hope-hero.jpg" alt="" aria-hidden="true" width="1600" height="1100"
          fetchpriority="high" decoding="async" class="h-full w-full object-cover object-[50%_60%]" />
      </picture>
      <div class="absolute inset-0" style="background:linear-gradient(96deg, rgb(26 12 5 / 0.66) 0%, rgb(26 12 5 / 0.36) 40%, rgb(26 12 5 / 0.06) 66%, rgb(26 12 5 / 0) 100%), linear-gradient(0deg, rgb(24 12 6 / 0.62) 0%, rgb(24 12 6 / 0) 48%)"></div>
    </div>

    <div class="container-x relative w-full pb-16 pt-32 sm:pb-20 lg:pb-24">
      <div class="max-w-2xl">
        <LiveStatus variant="dark" class="mb-6" />
        <p class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-white/85">
          <Icon name="Sun" size={16} class="text-amber" />Begleitung bei Krebs &amp; schweren Erkrankungen
        </p>
        <h1 class="mt-4 text-balance font-display text-[2.6rem] font-medium leading-[1.06] text-white sm:text-6xl lg:text-[4rem]"
          style="text-shadow:0 2px 30px rgba(0,0,0,0.4)">
          An Ihrer Seite - mit Kraft, Ruhe und Wärme.
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/90 text-pretty sm:text-xl" style="text-shadow:0 1px 12px rgba(0,0,0,0.45)">
          Eine Diagnose verändert alles. Ich begleite Sie eine Woche lang in meiner Praxis am Stechlinsee -
          mit drei Behandlungen, die Kraft geben. Ergänzend zu Ihrer ärztlichen Therapie, seit {site.since}.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href={site.phone.href} class="btn btn-amber inline-flex items-center justify-center gap-2 text-base">
            <Icon name="Phone" size={18} />Termin anfragen
          </a>
          <a href="#die-woche" class="btn btn-on-dark inline-flex items-center justify-center gap-2 text-base">
            Die Woche kennenlernen<Icon name="ArrowRight" size={18} />
          </a>
        </div>
      </div>

      <!-- Gestapelte Glas-Bewertungen rechts im Hero (ab xl) -->
      <div class="absolute right-0 top-1/2 z-10 hidden w-[19.5rem] -translate-y-1/2 xl:block">
        <figure class="absolute inset-x-0 top-0 -translate-y-[4.75rem] translate-x-8 rotate-[5deg] rounded-3xl border border-white/10 bg-white/[0.05] p-5 opacity-50 shadow-lift backdrop-blur-md">
          <blockquote class="text-sm leading-snug text-white/85">„Heute geht es mir sehr gut - wir haben neue Energie gewonnen."</blockquote>
          <figcaption class="mt-1.5 text-xs text-white/55">H. Maybaum</figcaption>
        </figure>
        <figure class="absolute inset-x-0 top-0 -translate-y-9 translate-x-4 rotate-[2.5deg] rounded-3xl border border-white/15 bg-white/[0.08] p-5 opacity-80 shadow-lift backdrop-blur-lg">
          <blockquote class="text-sm leading-snug text-white/90">„Das Gesamtpaket hat mir Gesundheit und Vitalität zurückgebracht."</blockquote>
          <figcaption class="mt-1.5 text-xs text-white/60">E. Lehnst</figcaption>
        </figure>
        <figure class="relative rounded-3xl border border-white/25 bg-white/[0.14] p-6 shadow-lift backdrop-blur-xl">
          <div class="flex items-center gap-2.5">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-white">
              <Social name="google" class="h-4 w-4" />
            </span>
            <span class="font-display text-base leading-none text-white">{site.google.rating}</span>
            <span class="flex gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="Star" size={13} class="text-amber fill-amber" strokeWidth={1.5} />
              ))}
            </span>
            <span class="text-xs text-white/70">Google</span>
          </div>
          <blockquote class="mt-3 text-[0.95rem] leading-relaxed text-white/90">„Ich fühle mich wie neu geboren und habe meine Lebensqualität zurückgewonnen."</blockquote>
          <figcaption class="mt-2 text-xs text-white/60">Corinna B. · Berlin</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ─────────────────── Die Praxis stellt sich vor (Video) ─────────────────── -->
  <section id="praxis" class="bg-paper">
    <div class="container-x py-20 lg:py-28">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <span class="eyebrow mb-4">Die Praxis stellt sich vor</span>
          <h2 class="text-balance text-3xl text-ink sm:text-4xl lg:text-[2.6rem]">
            Lernen Sie mich und meine Praxis kennen.
          </h2>
          <div class="mt-5 space-y-4 leading-relaxed text-ink-soft">
            <p>
              Mein Name ist Dr. Fabian Forbrig. In meiner Praxis in Neuglobsow am Stechlinsee begleite ich
              Menschen mit Krebs und schweren Erkrankungen - mit Zeit, Wärme und Ruhe, ergänzend zu ihrer
              ärztlichen Behandlung.
            </p>
            <p>
              Wer zu mir kommt, bleibt eine Woche und schöpft neue Kraft. Im Video stelle ich mich und meine
              Arbeit ganz persönlich vor.
            </p>
          </div>
          <a href="/ueber-mich" class="mt-8 inline-flex items-center gap-1.5 font-semibold text-clay-deep hover:text-clay-ink">
            Mehr über meinen Weg<Icon name="ArrowRight" size={17} />
          </a>
        </div>

        <div class="reveal">
          <VideoEmbed id={introVideo.id} title={introVideo.title} />
          <p class="mt-3 flex items-center gap-2 text-sm text-muted">
            <Icon name="Sun" size={15} class="text-amber-deep" />Dr. Fabian Forbrig - Heiler für Mensch und Tier
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────── Die Woche bei mir (Signatur) ─────────────────── -->
  <section id="die-woche" class="scroll-mt-24 bg-sand">
    <div class="container-x py-20 lg:py-28">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:gap-16">
        <div>
          <SectionHeading
            eyebrow={wochenprogramm.kicker}
            title={wochenprogramm.title}
            lead={wochenprogramm.intro}
            class="reveal"
          />
          <ol class="mt-9 space-y-5">
            {wochenprogramm.steps.map((s) => (
              <li class="reveal flex gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-clay-deep font-display text-lg text-white">{s.n}</span>
                <div>
                  <h3 class="font-display text-lg text-ink">{s.title}</h3>
                  <p class="mt-1 text-[0.95rem] leading-relaxed text-ink-soft">{s.text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="reveal">
          <div class="overflow-hidden rounded-3xl shadow-lift">
            <img src="/images/warm-room.jpg" alt="Ein warmer, sonnendurchfluteter Raum zum Ankommen"
              width="1000" height="750" loading="lazy" decoding="async" class="h-60 w-full object-cover sm:h-72" />
          </div>
          <div class="mt-5 rounded-3xl border border-line bg-white p-7 shadow-soft">
            <p class="text-sm font-semibold uppercase tracking-wide text-clay-ink">{wochenprogramm.priceLabel}</p>
            <p class="mt-1 font-display text-4xl text-ink">{wochenprogramm.price}</p>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{wochenprogramm.priceNote}</p>
            <div class="mt-6 flex flex-col gap-2.5 sm:flex-row">
              <a href={site.phone.href} class="btn btn-primary inline-flex items-center justify-center gap-2">
                <Icon name="Phone" size={16} />Termin anfragen
              </a>
              <a href="/behandlung/begleitende-behandlung" class="btn btn-outline inline-flex items-center justify-center gap-2">
                Mehr zur Begleitung<Icon name="ArrowRight" size={16} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Methoden ───────────────────────── -->
  <section class="bg-paper">
    <div class="container-x py-20 lg:py-28">
      <SectionHeading
        eyebrow="Methoden"
        title="Womit ich Sie begleite."
        lead="Es geht um den Menschen - um Kraft, Ruhe und die Stärkung der Selbstheilung."
        class="reveal max-w-2xl"
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {methods.map((m) => (
          <ServiceCard href={`/methoden/${m.slug}`} icon={m.icon} title={m.name} blurb={m.short} image={m.image} cta="Mehr erfahren" />
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────── weitere Begleitung ───────────────── -->
  <section class="bg-mist">
    <div class="container-x py-20 lg:py-28">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end lg:gap-16">
        <SectionHeading
          eyebrow="Weitere Begleitung"
          title="Ich begleite auch bei …"
          lead="Neben der Begleitung bei Krebs unterstütze ich bei einem breiteren Spektrum - selbstbewusst beschreibend, immer als Begleitung."
          class="reveal"
        />
        <p class="reveal text-[0.95rem] leading-relaxed text-muted lg:pb-2">
          Auch hier gilt: Ich unterstütze, lindere und begleite - ergänzend zu Ihrer ärztlichen Behandlung,
          nie an ihrer Stelle.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-3">
        {weitere.map((t) => (
          <a href={`/behandlung/${t.slug}`} class="card card-hover group reveal flex flex-col p-7">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep transition-colors group-hover:bg-clay-deep group-hover:text-white">
              <Icon name={t.icon} size={23} strokeWidth={1.8} />
            </span>
            <h3 class="mt-5 font-display text-xl text-ink">{t.name}</h3>
            <p class="mt-2 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">{t.short}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-clay-deep">
              Mehr erfahren<Icon name="ArrowRight" size={15} class="transition-transform duration-300 group-hover:translate-x-1" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Philosophie ───────────────────────── -->
  <section class="bg-paper">
    <div class="container-x py-20 lg:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <Icon name="Sun" size={32} class="mx-auto text-amber-deep" strokeWidth={1.6} />
        <blockquote class="reveal mt-6 text-balance font-display text-2xl leading-snug text-ink sm:text-3xl lg:text-[2.4rem] lg:leading-[1.2]">
          „Die Kräfte der Selbstheilung sind größer, als die meisten Menschen glauben."
        </blockquote>
        <p class="reveal mx-auto mt-6 max-w-xl leading-relaxed text-ink-soft text-pretty">
          Ich gehe an die Wurzeln - und gebe Ihnen Kraft, Ruhe und Zuversicht für Ihren Weg.
        </p>
      </div>
    </div>
  </section>

  <!-- ─────────────── Einblicke: Videos & Podcast ─────────────── -->
  <section class="bg-sand">
    <div class="container-x py-20 lg:py-28">
      <SectionHeading
        eyebrow="Einblicke"
        title="Sehen, hören, ein Gefühl bekommen."
        lead="Lernen Sie meine Arbeit in Ruhe kennen - in zwei Videos und einem ausführlichen Podcast-Gespräch."
        class="reveal max-w-2xl"
      />
      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {videos.map((v) => (
          <div class="reveal"><VideoEmbed id={v.id} title={v.title} /></div>
        ))}
      </div>
      <p class="reveal mt-6 text-sm text-muted">
        Videos &amp; Podcast laden erst nach Klick (YouTube, datenschutzfreundlich). Der Podcast erscheint bei
        <a href={`https://www.youtube.com/watch?v=${videos[2].id}`} target="_blank" rel="noopener noreferrer" class="font-semibold text-clay-deep hover:text-clay-ink">„Gesundheit für Empathen"</a>.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── Google-Bewertungen (Glaseffekt) ───────────────────────── -->
  <GoogleReviews image="/images/golden-water.jpg" />

  <!-- ───────────────────────── Kosten-Teaser ───────────────────────── -->
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-20">
      <div class="reveal flex flex-col items-center justify-between gap-6 rounded-3xl border border-line bg-sand px-7 py-9 text-center sm:px-10 md:flex-row md:text-left">
        <div class="flex items-start gap-4">
          <span class="hidden h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep sm:inline-flex">
            <Icon name="HandHeart" size={23} strokeWidth={1.8} />
          </span>
          <div>
            <h2 class="font-display text-2xl text-ink">Transparente Kosten, ehrlich genannt.</h2>
            <p class="mt-2 max-w-xl leading-relaxed text-ink-soft">
              Die Woche bei mir kostet zwischen <strong class="text-ink">1.800 und 3.000 €</strong> - je nach
              individuellem Behandlungskomplex. Alle weiteren Honorare finden Sie offen aufgelistet.
            </p>
          </div>
        </div>
        <a href="/kosten" class="btn btn-outline inline-flex shrink-0 items-center gap-2">
          Zu den Kosten<Icon name="ArrowRight" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Kontakt & Anfahrt ───────────────────────── -->
  <section id="kontakt" class="bg-mist">
    <div class="container-x py-20 lg:py-28">
      <SectionHeading
        eyebrow="Kontakt"
        title="Gehen wir den ersten Schritt - am Telefon."
        lead="Termine und Fragen besprechen wir am liebsten persönlich. Rufen Sie an, schreiben Sie - ich nehme mir Zeit für Sie."
        align="center"
        class="reveal mx-auto"
      />
      <div class="mx-auto mt-12 max-w-5xl">
        <ContactTiles />
      </div>
      <div class="mt-6 grid gap-6 lg:grid-cols-2 lg:items-stretch">
        <div class="reveal"><Sprechzeiten /></div>
        <div class="reveal"><MapBlock src={site.maps.embed} link={site.maps.link} label={`${site.name}, ${site.address.street}, ${site.address.zip} ${site.address.city}`} /></div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
