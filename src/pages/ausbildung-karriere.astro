---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import Jobanzeige from '../components/Jobanzeige.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';
import { werte, ausbildungen, jobs } from '../data/jobs';
---
<Layout title="Ausbildung & Karriere" description="Bei uns lernen, heilen, wachsen: Ausbildung in Geistheilung, Reiki und Meditation und Mitarbeit in der Gesundheitspraxis SonnenTor am Stechlinsee." current="/ausbildung-karriere">
  <PageHero
    eyebrow="Ausbildung & Karriere"
    title="Bei uns lernen, heilen, wachsen."
    lead="Diese Praxis bildet aus - in Geistheilung, Reiki und Meditation. Wenn Sie spüren, dass dieser Weg zu Ihnen gehört, lade ich Sie ein, ihn an meiner Seite zu gehen."
    image="/images/path-forest.jpg"
    breadcrumb={[{ label: 'Ausbildung & Karriere' }]}
  />

  <!-- So arbeiten wir -->
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-24">
      <div class="reveal max-w-2xl">
        <span class="eyebrow mb-4">So arbeiten wir</span>
        <h2 class="text-balance text-3xl text-ink sm:text-4xl">Kein Konzern-Recruiting. Ein gemeinsamer Weg.</h2>
        <p class="mt-5 leading-relaxed text-ink-soft">
          Hier zählt nicht Tempo, sondern Achtsamkeit. Sie lernen nicht in anonymen Kursen, sondern direkt
          an meiner Seite - im Gespräch, in der Behandlung, Schritt für Schritt.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {werte.map((w) => (
          <div class="reveal rounded-3xl border border-line bg-white p-7 shadow-soft">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-sage-tint text-sage-ink">
              <Icon name={w.icon} size={22} strokeWidth={1.8} />
            </span>
            <h3 class="mt-5 font-display text-lg text-ink">{w.title}</h3>
            <p class="mt-2 text-[0.92rem] leading-relaxed text-ink-soft">{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Der Ort -->
  <section class="bg-sand">
    <div class="container-x py-16 lg:py-24">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="reveal order-2 lg:order-1">
          <div class="overflow-hidden rounded-3xl shadow-lift">
            <img src="/images/reed-lake.jpg" alt="Schilf am Stechlinsee im warmen Abendlicht"
              width="1000" height="700" loading="lazy" decoding="async" class="h-64 w-full object-cover sm:h-96" />
          </div>
        </div>
        <div class="reveal order-1 lg:order-2">
          <span class="eyebrow mb-4">Der Ort</span>
          <h2 class="text-balance text-3xl text-ink sm:text-4xl">Wald, Wasser und Stille - als Teil der Arbeit.</h2>
          <p class="mt-5 leading-relaxed text-ink-soft">
            Wir arbeiten in Neuglobsow am Stechlinsee, einem der klarsten Seen Norddeutschlands. Die Ruhe
            dieses Ortes ist kein Beiwerk - sie trägt die Arbeit und gibt ihr Raum.
          </p>
          <p class="mt-4 leading-relaxed text-ink-soft">
            Wer hier lernt, lernt in einer Umgebung, die zur Konzentration und zum Zur-Ruhe-Kommen einlädt.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Das bilden wir aus -->
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-24">
      <div class="reveal mx-auto max-w-2xl text-center">
        <span class="eyebrow no-rule mb-4 justify-center">Das bilden wir aus</span>
        <h2 class="text-balance text-3xl text-ink sm:text-4xl">Bis zur Lehrbefähigung.</h2>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Vier Wege, die Sie vollständig erlernen können - jeden bis zur Stufe des Lehrers, im System RA-MARIA.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {ausbildungen.map((a) => (
          <div class="reveal flex flex-col items-start rounded-3xl border border-line bg-white p-7 shadow-soft">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep">
              <Icon name={a.icon} size={22} strokeWidth={1.8} />
            </span>
            <h3 class="mt-5 font-display text-lg text-ink">{a.name}</h3>
            <p class="mt-1.5 text-[0.92rem] leading-relaxed text-muted">{a.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Jobanzeigen -->
  <section class="bg-mist">
    <div class="container-x py-16 lg:py-24">
      <div class="reveal mx-auto mb-12 max-w-2xl text-center">
        <span class="eyebrow no-rule mb-4 justify-center">Offene Wege</span>
        <h2 class="text-balance text-3xl text-ink sm:text-4xl">So können Sie Teil werden.</h2>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Zwei ehrliche Wege zu uns. Vieles - Umfang, Modell, Beginn - besprechen wir am liebsten persönlich.
        </p>
      </div>
      <div class="mx-auto flex max-w-4xl flex-col gap-6">
        {jobs.map((job) => <Jobanzeige job={job} />)}
      </div>
    </div>
  </section>

  <!-- Bewerbungs-CTA -->
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-20">
      <div class="reveal flex flex-col items-center gap-6 rounded-3xl border border-line bg-sand px-7 py-10 text-center sm:px-12">
        <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep">
          <Icon name="Send" size={26} strokeWidth={1.8} />
        </span>
        <div>
          <h2 class="text-balance font-display text-2xl text-ink sm:text-3xl">Klingt nach Ihrem Weg?</h2>
          <p class="mx-auto mt-3 max-w-xl leading-relaxed text-ink-soft">
            Dann freue ich mich über Ihre Nachricht. Erzählen Sie mir in ein paar Sätzen von sich und dem,
            was Sie antreibt - wir finden gemeinsam heraus, was passt.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href={site.phone.href} class="btn btn-primary inline-flex items-center justify-center gap-2">
            <Icon name="Phone" size={17} />{site.phone.display}
          </a>
          <a href={`mailto:${site.email}?subject=${encodeURIComponent('Bewerbung Gesundheitspraxis SonnenTor')}`} class="btn btn-outline inline-flex items-center justify-center gap-2">
            <Icon name="Mail" size={17} />Per E-Mail bewerben
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Lernen Sie mich kennen." text="Der beste erste Schritt ist ein Gespräch. Rufen Sie an - ich nehme mir Zeit, Ihre Fragen zu beantworten." />
</Layout>
