---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import CtaBand from '../components/CtaBand.astro';
import { honorarGroups } from '../data/honorar';
import { wochenprogramm } from '../data/treatments';
import { site } from '../data/site';
---
<Layout title="Kosten" description="Transparente Honorare der Gesundheitspraxis SonnenTor. Die Woche bei mir (Begleitung bei Krebs) kostet 1.800-3.000 € - alle weiteren Honorare offen aufgelistet." current="/kosten">
  <PageHero
    eyebrow="Kosten"
    title="Transparente Honorare, ehrlich genannt."
    lead="Jede Begleitung ist individuell. Hier finden Sie die Honorare offen aufgelistet - die genaue Zusammenstellung besprechen wir in Ruhe im Erstgespräch."
    breadcrumb={[{ label: 'Kosten' }]}
  />

  <!-- Signatur: Die Woche bei mir -->
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-20">
      <div class="reveal grid gap-8 rounded-3xl border border-clay/25 bg-clay-tint/60 p-8 sm:p-10 lg:grid-cols-[1.3fr_1fr] lg:items-center">
        <div>
          <span class="eyebrow mb-4">{wochenprogramm.kicker}</span>
          <h2 class="text-balance text-3xl text-ink sm:text-4xl">{wochenprogramm.title}</h2>
          <p class="mt-4 leading-relaxed text-ink-soft">{wochenprogramm.intro}</p>
          <ul class="mt-6 grid gap-2.5 sm:grid-cols-3">
            {wochenprogramm.steps.map((s) => (
              <li class="flex items-start gap-2.5 text-[0.92rem] leading-snug text-ink-soft">
                <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-deep text-xs font-bold text-white">{s.n}</span>{s.title}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl border border-line bg-white p-7 text-center shadow-soft">
          <p class="text-sm font-semibold uppercase tracking-wide text-clay-ink">{wochenprogramm.priceLabel}</p>
          <p class="mt-1 font-display text-4xl text-ink sm:text-5xl">{wochenprogramm.price}</p>
          <p class="mt-3 text-sm leading-relaxed text-muted">{wochenprogramm.priceNote}</p>
          <a href={site.phone.href} class="btn btn-primary mt-6 inline-flex w-full items-center justify-center gap-2">
            <Icon name="Phone" size={16} />Termin anfragen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Weitere Honorare -->
  <section class="bg-sand">
    <div class="container-x py-16 lg:py-24">
      <h2 class="reveal font-display text-2xl text-ink sm:text-3xl">Weitere Honorare</h2>
      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        {honorarGroups.map((g) => (
          <div class="reveal rounded-3xl border border-line bg-white p-7 shadow-soft sm:p-8">
            <h3 class="flex items-center gap-2.5 font-display text-xl text-ink">
              <Icon name="HandCoins" size={22} class="text-clay-deep" />{g.title}
            </h3>
            {g.note && <p class="mt-2 text-sm leading-relaxed text-muted">{g.note}</p>}
            <dl class="mt-5 space-y-4">
              {g.items.map((it) => (
                <div class="flex items-baseline justify-between gap-4 border-b border-line/70 pb-4 last:border-0 last:pb-0">
                  <dt>
                    <span class="block text-[0.98rem] font-medium text-ink">{it.label}</span>
                    {it.sub && <span class="mt-0.5 block text-sm leading-relaxed text-muted">{it.sub}</span>}
                  </dt>
                  <dd class="shrink-0 font-display text-lg text-clay-ink">{it.price}</dd>
                </div>
              ))}
            </dl>
          </div>
        ))}
      </div>

      <p class="reveal mt-8 flex items-start gap-3 rounded-3xl bg-paper px-6 py-5 text-[0.95rem] leading-relaxed text-ink-soft">
        <Icon name="Heart" size={19} class="mt-0.5 shrink-0 text-clay-deep" />
        Behandlungskomplexe umfassen mehrere Sitzungen mit Therapiegespräch, abgestimmtem Behandlungskomplex und
        einem Trainingsprogramm für zu Hause. Welche Begleitung für Sie sinnvoll ist, klären wir gemeinsam,
        bevor Sie sich entscheiden.
      </p>
    </div>
  </section>

  <CtaBand />
</Layout>
