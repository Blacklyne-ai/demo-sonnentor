---
import Icon from './Icon.astro';
import { testimonials } from '../data/testimonials';
import { disclaimer } from '../data/site';
interface Props { limit?: number }
const { limit } = Astro.props;
const items = limit ? testimonials.slice(0, limit) : testimonials;
---
<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
  {items.map((t) => (
    <figure class="card reveal flex flex-col p-6 sm:p-7">
      <Icon name="Quote" size={26} class="text-amber" strokeWidth={1.6} />
      <blockquote class="mt-3 flex-1 leading-relaxed text-ink-soft">{t.quote}</blockquote>
      <figcaption class="mt-5 border-t border-line pt-4">
        <span class="block font-display text-ink">{t.author}</span>
        <span class="mt-0.5 block text-sm text-muted">
          {t.context}{t.location && ` · ${t.location}`}
        </span>
      </figcaption>
    </figure>
  ))}
</div>
<p class="mt-6 flex items-start gap-2 text-sm leading-relaxed text-muted">
  <Icon name="ShieldCheck" size={15} class="mt-0.5 shrink-0" />
  {disclaimer.testimonial}
</p>
