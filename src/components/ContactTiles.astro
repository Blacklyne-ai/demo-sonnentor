---
import Icon from './Icon.astro';
import { site, sprechzeit } from '../data/site';
// Kein Formular/Backend (DSGVO im Gesundheitskontext + Nutzer-Präferenz):
// direkte, datensparsame Kanäle als Tiles. WhatsApp/Telefon/E-Mail/Anfahrt.
const subject = encodeURIComponent('Anfrage über die Website');
const body = encodeURIComponent(
  'Hallo Herr Forbrig,\n\nich würde mich gern bei Ihnen vorstellen. Es geht um:\n\nIn zwei, drei Sätzen mein Anliegen:\n\nGern können wir telefonieren. Viele Grüße',
);
const tiles = [
  { icon: 'Phone', label: 'Anrufen', value: site.phone.display, href: site.phone.href, note: `Sprechzeit ${sprechzeit.daysLabel.replace(' - ', '-')} ${sprechzeit.timeLabel}` },
  { icon: 'MessageCircle', label: 'WhatsApp', value: site.whatsapp.display, href: site.whatsapp.href, note: 'Kurze Nachricht schreiben', external: true },
  { icon: 'Mail', label: 'E-Mail', value: site.email, href: `mailto:${site.email}?subject=${subject}&body=${body}`, note: 'Ich antworte persönlich' },
  { icon: 'MapPin', label: 'Anfahrt', value: `${site.address.city} am Stechlinsee`, href: site.maps.link, note: 'Route planen', external: true },
] as const;
---
<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {tiles.map((t) => (
    <a href={t.href} {...('external' in t && t.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      class="card card-hover group reveal flex flex-col gap-3 p-6">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-clay-tint text-clay-deep transition-colors group-hover:bg-clay-deep group-hover:text-white">
        <Icon name={t.icon} size={22} />
      </span>
      <span>
        <span class="block font-display text-lg text-ink">{t.label}</span>
        <span class="mt-0.5 block font-semibold text-clay-deep break-words">{t.value}</span>
        <span class="mt-1 block text-sm text-muted">{t.note}</span>
      </span>
    </a>
  ))}
</div>
