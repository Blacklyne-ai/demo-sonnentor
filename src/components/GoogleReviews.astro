---
import Icon from './Icon.astro';
import Social from './Social.astro';
import { site, disclaimer } from '../data/site';
import { testimonials } from '../data/testimonials';
// Glassmorphism-Sektion. Zeigt das ECHTE Google-Rating (5,0) + Link zum Profil und
// die echten Erfahrungsberichte als Glaskarten. KEINE erfundenen Google-Rezensionen;
// die Zitate sind klar als Erfahrungsberichte (Patientenstimmen) ausgewiesen.
interface Props { variant?: 'full' | 'compact'; image?: string; limit?: number }
const { variant = 'full', image = '/images/sunrise-warm.jpg', limit = 3 } = Astro.props;
const items = testimonials.slice(0, limit);
---
<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <img src={image} alt="" aria-hidden="true" width="1600" height="1100" loading="lazy" decoding="async" class="h-full w-full object-cover object-center" />
    <div class="absolute inset-0" style="background:linear-gradient(180deg, rgb(22 15 12 / 0.84), rgb(22 15 12 / 0.76))"></div>
  </div>

  <div class="container-x py-20 lg:py-28">
    <div class:list={['reveal', variant === 'compact' ? 'mx-auto max-w-2xl text-center' : 'max-w-2xl']}>
      <span class:list={['eyebrow mb-4 !text-amber-tint', variant === 'compact' && 'justify-center']}>Bewertungen</span>
      <h2 class="text-balance text-3xl font-medium text-white sm:text-4xl lg:text-[2.6rem]" style="text-shadow:0 2px 24px rgba(0,0,0,0.4)">
        Vertrauen, das von Menschen kommt.
      </h2>
      <p class="mt-4 leading-relaxed text-white/80 text-pretty">
        Schauen Sie sich meine Bewertung bei Google an - und lesen Sie, was Menschen erzählen,
        die ich ein Stück ihres Weges begleiten durfte.
      </p>
    </div>

    <div class:list={['mt-12 grid gap-5', variant === 'full' ? 'sm:grid-cols-2 lg:grid-cols-4 lg:items-stretch' : 'mx-auto max-w-md']}>
      <!-- Google-Glaskarte (echtes Rating) -->
      <div class="reveal flex flex-col justify-between rounded-3xl border border-white/20 bg-white/10 p-7 shadow-lift backdrop-blur-xl">
        <div>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white shadow-soft">
              <Social name="google" class="h-6 w-6" />
            </span>
            <span class="font-display text-xl text-white">Google</span>
          </div>
          <div class="mt-6 flex items-end gap-3">
            <span class="font-display text-5xl leading-none text-white">{site.google.rating}</span>
            <span class="pb-1">
              <span class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <Icon name="Star" size={16} class="text-amber fill-amber" strokeWidth={1.5} />
                ))}
              </span>
              <span class="mt-1 block text-xs text-white/70">von 5 Sternen</span>
            </span>
          </div>
          <p class="mt-4 text-[0.95rem] leading-relaxed text-white/70">
            Echte Bewertungen direkt bei Google - schön, wenn auch Sie Ihre Erfahrung teilen.
          </p>
        </div>
        <a href={site.google.url} target="_blank" rel="noopener noreferrer"
          class="mt-6 inline-flex items-center justify-center gap-2 rounded-pill border border-white/25 bg-white/15 px-5 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/25">
          Auf Google ansehen<Icon name="ArrowUpRight" size={16} />
        </a>
      </div>

      <!-- Erfahrungsberichte als Glaskarten - in einer Reihe neben der Google-Karte -->
      {variant === 'full' && items.map((t) => (
        <figure class="reveal flex flex-col rounded-3xl border border-white/15 bg-white/10 p-6 shadow-lift backdrop-blur-xl">
          <Icon name="Quote" size={22} class="text-amber" strokeWidth={1.6} />
          <blockquote class="mt-3 flex-1 text-[0.92rem] leading-relaxed text-white/90">{t.quote}</blockquote>
          <figcaption class="mt-4 border-t border-white/15 pt-3">
            <span class="block font-display text-white">{t.author}</span>
            <span class="mt-0.5 block text-sm text-white/60">{t.context}{t.location && ` · ${t.location}`}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    {variant === 'full' && (
      <div class="reveal mt-7 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="flex items-start gap-2 text-sm leading-relaxed text-white/55">
          <Icon name="ShieldCheck" size={15} class="mt-0.5 shrink-0" />{disclaimer.testimonial}
        </p>
        <a href="/erfahrungsberichte" class="inline-flex shrink-0 items-center gap-1.5 font-semibold text-amber-tint transition-colors hover:text-white">
          Alle Erfahrungsberichte<Icon name="ArrowRight" size={16} />
        </a>
      </div>
    )}
  </div>
</section>
