---
import Icon from './Icon.astro';
import { site, footerNav, disclaimer } from '../data/site';
const year = 2026;
---
<footer class="border-t border-white/5 bg-dark-deep text-white/70">
  <div class="container-x py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <!-- Brand + Kontakt -->
      <div>
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="" aria-hidden="true" width="48" height="48" loading="lazy" class="h-11 w-11" />
          <span class="leading-none">
            <span class="block text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-white/55">Gesundheitspraxis</span>
            <span class="mt-1 block font-display text-2xl text-white">SonnenTor</span>
          </span>
        </div>
        <p class="mt-5 max-w-xs text-[0.95rem] leading-relaxed text-white/65">
          {site.kicker} in {site.place}. Geistiges Heilen mit Herz - seit {site.since}.
        </p>
        <div class="mt-6 space-y-2.5 text-[0.95rem]">
          <a href={site.phone.href} class="flex items-center gap-3 text-white transition-colors hover:text-amber">
            <Icon name="Phone" size={17} class="text-amber" />{site.phone.display}
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-3 break-all text-white transition-colors hover:text-amber">
            <Icon name="Mail" size={17} class="shrink-0 text-amber" />{site.email}
          </a>
          <p class="flex items-start gap-3 text-white/65">
            <Icon name="MapPin" size={17} class="mt-0.5 shrink-0 text-amber" />
            {site.address.street}, {site.address.zip} {site.address.city}
          </p>
        </div>
        <a href={site.phone.href} class="btn btn-amber mt-7 inline-flex items-center gap-2">
          <Icon name="Phone" size={17} />Termin anfragen
        </a>
      </div>

      <!-- Nav-Spalten -->
      {footerNav.map((col) => (
        <div>
          <h3 class="font-display text-base text-white">{col.title}</h3>
          <ul class="mt-4 space-y-2.5 text-[0.92rem]">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-white/65 transition-colors hover:text-white">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Vertrauenssatz statt Marktschrei -->
    <p class="mt-14 flex items-start gap-2.5 border-t border-white/10 pt-7 text-sm leading-relaxed text-white/55">
      <Icon name="Heart" size={16} class="mt-0.5 shrink-0 text-amber" />
      {disclaimer.noPromise} Meine Methoden aktivieren die Selbstheilungskräfte und ersetzen nicht die Tätigkeit eines Arztes oder Psychologen.
    </p>

    <div class="mt-7 flex flex-col gap-3 text-sm text-white/55 sm:flex-row sm:items-center sm:justify-between">
      <p>© {site.since}-{year} {site.name}</p>
      <p class="flex flex-wrap items-center gap-x-5 gap-y-1">
        <a href="/impressum" class="transition-colors hover:text-white">Impressum</a>
        <a href="/datenschutz" class="transition-colors hover:text-white">Datenschutz</a>
        <a href="/kontakt" class="transition-colors hover:text-white">Kontakt</a>
      </p>
    </div>
  </div>
</footer>
